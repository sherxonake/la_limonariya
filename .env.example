# Postgres parol (docker-compose o'qiydi). Productionda kuchli parol qo'ying.
POSTGRES_PASSWORD=limon_dev

# Web host port (LAN'da shu portda ochiladi). Default 8080 — serverda 80 bandligini
# olib qo'ymaydi. Agar serverda 80 bo'sh bo'lsa: WEB_PORT=80 → http://192.168.1.4
WEB_PORT=8080

# PIN auth: pepper (PIN'larni himoyalaydi — productionda tasodifiy uzun qiymat qo'ying)
PIN_PEPPER=dev-pepper-change-me
# Direktorning bootstrap PIN'i (birinchi kirish uchun — keyin almashtiring)
BOOTSTRAP_DIRECTOR_PIN=1234

# Necha kunlik backup saqlansin (./backups/, eskisi avtomatik o'chadi)
BACKUP_KEEP_DAYS=14

# Ixtiyoriy — API xatosi bo'lsa Telegram'ga xabar keladi (@BotFather'dan bot
# yarating, chatga qo'shing, chat id'ni oling). Bo'sh qoldirsangiz xatolar
# faqat `docker compose logs api`da ko'rinadi.
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
